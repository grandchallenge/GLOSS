{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gcl.example/gloss/rule.schema.json",
  "title": "GLOSS Rule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_id",
    "version",
    "status",
    "class",
    "match",
    "renderings",
    "loss_policy",
    "fixtures",
    "provenance",
    "compatibility"
  ],
  "properties": {
    "rule_id": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+$"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "enum": [
        "experimental",
        "candidate",
        "approved",
        "deprecated",
        "retired"
      ]
    },
    "class": {
      "enum": [
        "lexical",
        "structural",
        "construct",
        "compression",
        "pronunciation",
        "normalization",
        "proof_narration"
      ]
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "head"
      ],
      "properties": {
        "head": {
          "type": "string"
        },
        "node_kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "type_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "slots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "renderings": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "loss_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification"
      ],
      "properties": {
        "classification": {
          "enum": [
            "exact",
            "compression",
            "lossy"
          ]
        },
        "covered_slots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "compressed_slots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "elided_slots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "fixtures": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "positive",
        "negative"
      ],
      "properties": {
        "positive": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "negative": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proposer",
        "evidence"
      ],
      "properties": {
        "proposer": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "corpus_build": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lean_min",
        "lean_max"
      ],
      "properties": {
        "lean_min": {
          "type": "string"
        },
        "lean_max": {
          "type": "string"
        }
      }
    },
    "review": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "replacement_rule_id": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
