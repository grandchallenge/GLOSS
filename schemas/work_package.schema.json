{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gcl.example/gloss/work_package.schema.json",
  "title": "GLOSS WorkPackage",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "owner", "dependencies", "deliverables", "acceptance_criteria", "required_reviews", "status"],
  "properties": {
    "id": {"type": "string", "pattern": "^WP[0-9]+$"},
    "title": {"type": "string"},
    "owner": {"type": "string"},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "deliverables": {"type": "array", "items": {"type": "string"}},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "required_reviews": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "unresolved_obligations": {"type": "array", "items": {"type": "string"}},
    "status": {"enum": ["planned", "active", "blocked", "review", "complete", "cancelled"]}
  }
}
