{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gcl.example/gloss/fixture.schema.json",
  "title": "GLOSS Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "lean",
    "expectations",
    "tags"
  ],
  "properties": {
    "fixture_id": {
      "type": "string"
    },
    "lean": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module",
        "source",
        "declaration"
      ],
      "properties": {
        "module": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "declaration": {
          "type": "string"
        }
      }
    },
    "expectations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "critical_features"
      ],
      "properties": {
        "critical_features": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonical_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "allowed_status": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_mutations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object"
    }
  }
}
