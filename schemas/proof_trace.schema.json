{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gcl.example/gloss/proof_trace.schema.json",
  "title": "GLOSS ProofTrace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "declaration",
    "steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "declaration": {
      "type": "string"
    },
    "toolchain": {
      "type": "object"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "tactic",
          "before",
          "after",
          "delta"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "tactic": {
            "type": "string"
          },
          "source_span": {
            "type": [
              "object",
              "null"
            ]
          },
          "before": {
            "type": "object"
          },
          "after": {
            "type": "object"
          },
          "delta": {
            "type": "object"
          },
          "narrations": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  }
}
